{
    "name": "scafera/layered-web",
    "description": "Project template for Scafera layered web applications",
    "type": "project",
    "license": "MIT",
    "keywords": ["scafera", "project-template", "layered-web", "php"],
    "homepage": "https://github.com/scafera/layered-web",
    "support": {
        "issues": "https://github.com/scafera/layered-web/issues",
        "source": "https://github.com/scafera/layered-web"
    },
    "require": {
        "php": ">=8.4",
        "scafera/database": "^1.0",
        "scafera/frontend": "^1.0",
        "scafera/layered": "^1.0",
        "scafera/scaffold": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "scafera/scaffold": true,
            "symfony/runtime": true
        }
    }
}
